{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Bash(npm run lint)",
            "Bash(npm run tests *)",
            "Read(~/.zshrc)"
        ]
    },
    "env": {
        "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
    },
    "hooks": {
        "Notification": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "notify-send '⏳ Claude is waiting for input' -u low -t 1500"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "notify-send '✅ Claude is done' -u low -t 1500"
                    }
                ]
            }
        ]
    }
}
