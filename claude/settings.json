{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "env": {
        "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
        "EDITOR": "nvim",
        "VISUAL": "nvim"
    },
    "permissions": {
        "defaultMode": "acceptEdits",
        "allow": [
            "Bash(ag)",
            "Bash(find)",
            "Bash(git add*)",
            "Bash(git blame*)",
            "Bash(git branch --list*)",
            "Bash(git branch --show-current*)",
            "Bash(git branch -a*)",
            "Bash(git branch -r*)",
            "Bash(git describe*)",
            "Bash(git diff*)",
            "Bash(git grep*)",
            "Bash(git log*)",
            "Bash(git ls-files*)",
            "Bash(git remote -v*)",
            "Bash(git rev-parse*)",
            "Bash(git shortlog*)",
            "Bash(git show*)",
            "Bash(git stash list*)",
            "Bash(git status*)",
            "Bash(git tag --list*)",
            "Bash(git tag -l*)",
            "Bash(grep)",
            "Bash(jq)",
            "Bash(ls)",
            "Bash(npm run build)",
            "Bash(npm run check*)",
            "Bash(npm run format)",
            "Bash(npm run lint)",
            "Bash(npm run tests*)",
            "Read(~/.zshrc)"
        ],
        "ask": [
            "Bash(git am*)",
            "Bash(git branch -D*)",
            "Bash(git branch -d*)",
            "Bash(git branch -m*)",
            "Bash(git checkout*)",
            "Bash(git cherry-pick*)",
            "Bash(git clean*)",
            "Bash(git commit*)",
            "Bash(git fetch*)",
            "Bash(git merge*)",
            "Bash(git pull*)",
            "Bash(git push*)",
            "Bash(git rebase*)",
            "Bash(git reset*)",
            "Bash(git restore*)",
            "Bash(git revert*)",
            "Bash(git stash apply*)",
            "Bash(git stash clear*)",
            "Bash(git stash drop*)",
            "Bash(git stash pop*)",
            "Bash(git switch*)",
            "Bash(git tag -d*)"
        ]
    },
    "hooks": {
        "Notification": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "paplay ~/.claude/bell.wav && notify-send '⏳ Waiting for input' -a Claude -u low -t 1500"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "paplay ~/.claude/bell.wav && notify-send '✅ Done' -a Claude -u low -t 1500"
                    }
                ]
            }
        ]
    },
    "statusLine": {
        "type": "command",
        "command": "bash ~/.claude/statusline-command.sh"
    },
    "enabledPlugins": {
        "superpowers@superpowers-marketplace": true
    },
    "autoMemoryEnabled": false,
    "theme": "dark-daltonized",
    "editorMode": "vim",
    "verbose": true,
    "effortLevel": "medium"
}
