{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "autoMemoryEnabled": false,
    "permissions": {
        "allow": [
            "Bash(npm run lint)",
            "Bash(npm run tests *)",
            "Read(~/.zshrc)"
        ]
    },
    "statusLine": {
        "type": "command",
        "command": "bash ~/.claude/statusline-command.sh"
    },
    "env": {
        "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
    },
    "hooks": {
        "Notification": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "notify-send '⏳ Waiting for input' -a Claude -u low -t 1500"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "notify-send '✅ Done' -a Claude -u low -t 1500"
                    }
                ]
            }
        ]
    }
}
