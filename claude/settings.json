{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "env": {
        "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
        "EDITOR": "vim",
        "VISUAL": "vim"
    },
    "permissions": {
        "allow": [
            "Bash(ag *)",
            "Bash(find *)",
            "Bash(gh pr diff*)",
            "Bash(gh pr view*)",
            "Bash(git add*)",
            "Bash(git blame*)",
            "Bash(git branch --list*)",
            "Bash(git branch --show-current*)",
            "Bash(git branch -a*)",
            "Bash(git branch -r*)",
            "Bash(git describe*)",
            "Bash(git diff*)",
            "Bash(git grep*)",
            "Bash(git log*)",
            "Bash(git ls-files*)",
            "Bash(git remote -v*)",
            "Bash(git rev-parse*)",
            "Bash(git shortlog*)",
            "Bash(git show*)",
            "Bash(git stash list*)",
            "Bash(git status*)",
            "Bash(git tag --list*)",
            "Bash(git tag -l*)",
            "Bash(grep *)",
            "Bash(jq *)",
            "Bash(ls *)",
            "Bash(npm run build)",
            "Bash(npm run check*)",
            "Bash(npm run format)",
            "Bash(npm run lint)",
            "Bash(npm run tests*)"
        ],
        "ask": [
            "Bash(git am*)",
            "Bash(git branch -D*)",
            "Bash(git branch -d*)",
            "Bash(git branch -m*)",
            "Bash(git checkout*)",
            "Bash(git cherry-pick*)",
            "Bash(git clean*)",
            "Bash(git commit*)",
            "Bash(git fetch*)",
            "Bash(git merge*)",
            "Bash(git pull*)",
            "Bash(git push*)",
            "Bash(git rebase*)",
            "Bash(git reset*)",
            "Bash(git restore*)",
            "Bash(git revert*)",
            "Bash(git stash apply*)",
            "Bash(git stash clear*)",
            "Bash(git stash drop*)",
            "Bash(git stash pop*)",
            "Bash(git switch*)",
            "Bash(git tag -d*)"
        ],
        "defaultMode": "acceptEdits"
    },
    "hooks": {
        "Notification": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash ~/.claude/bell-notify.sh waiting \"⏳ Waiting for input\""
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash ~/.claude/bell-notify.sh done \"✅ Done\""
                    }
                ]
            }
        ]
    },
    "statusLine": {
        "type": "command",
        "command": "bash ~/.claude/statusline-command.sh"
    },
    "enabledPlugins": {
        "superpowers@superpowers-marketplace": true,
        "superpowers@claude-plugins-official": true,
        "skill-creator@claude-plugins-official": true
    },
    "effortLevel": "medium",
    "tui": "fullscreen",
    "autoMemoryEnabled": false,
    "skipDangerousModePermissionPrompt": true,
    "theme": "dark-ansi",
    "editorMode": "normal",
    "verbose": true
}
