#!/bin/bash
# Thin wrapper around `docker compose` for the global singleton services
# project (broker, mcp-everything, ...), for diagnostics (e.g.
# `claude-devcontainer-compose logs -f`, `... ps`, `... down`). These
# services are normally started automatically by claude-devcontainer; use
# this script directly when you need to inspect or manage them outside of
# that flow.
#
# Usage: claude-devcontainer-compose <any docker compose subcommand/args>
set -euo pipefail

# Passed through so the compose file's UID interpolation resolves correctly.
export DEV_UID
DEV_UID="$(id -u)"

exec docker compose -f "$HOME/.dotfiles/devcontainer/docker-compose.yml" "$@"
