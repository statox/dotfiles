#!/usr/bin/env bash
# Runs Claude Code in an isolated Docker container.
#
# Mount strategy (all config mounts are read-only to protect host settings):
#   $PWD                                  -> /workdir                              (rw) current project files
#   ~/.dotfiles/claude/CLAUDE.md          -> /home/dev/.claude/CLAUDE.md          (ro) global instructions
#   ~/.dotfiles/claude/settings.json      -> /home/dev/.claude/settings.json      (ro) Claude Code settings
#   ~/.dotfiles/claude/bell.wav           -> /home/dev/.claude/bell.wav           (ro) notification sound
#   ~/.dotfiles/claude/statusline-command.sh -> /home/dev/.claude/statusline-command.sh (ro) statusline helper
#   ~/.claude/.credentials.json           -> /home/dev/.claude/.credentials.json  (ro) auth token
#   ~/.dotfiles/config/nvim/              -> /home/dev/.config/nvim/              (ro) neovim config (EDITOR=nvim)
#
# Individual file mounts are used (rather than mounting the whole claude/ directory) because
# Docker cannot bind-mount a file into a read-only bind-mounted directory.
# /home/dev/.claude/ itself is writable so Claude Code can write history and cache there;
# only the tracked dotfiles within it are read-only overlays.
#
# Container state (history, cache) lives inside the container and is discarded on exit.
#
# Usage:
#   claude-docker           # build image if missing, then run
#   claude-docker --rebuild # force image rebuild, then run

set -euo pipefail

DOTFILES="${HOME}/.dotfiles"
DOCKERFILE="${DOTFILES}/docker/claude/Dockerfile"
IMAGE_NAME="claude-docker"

REBUILD=0
for arg in "$@"; do
    [[ "$arg" == "--rebuild" ]] && REBUILD=1
done

if [[ "$REBUILD" == "1" ]] || ! docker image inspect "$IMAGE_NAME" &>/dev/null; then
    echo "Building ${IMAGE_NAME}..."
    docker build \
        --build-arg USER_UID="$(id -u)" \
        --build-arg USER_GID="$(id -g)" \
        -t "$IMAGE_NAME" -f "$DOCKERFILE" "${DOTFILES}/docker/claude"
fi


# Use `--entrypoint bash` for interactive debug
exec docker run --rm -it \
    -v "${PWD}:/workdir" \
    -v "${DOTFILES}/claude/CLAUDE.md:/home/dev/.claude/CLAUDE.md:ro" \
    -v "${DOTFILES}/claude/settings.json:/home/dev/.claude/settings.json:ro" \
    -v "${DOTFILES}/claude/bell.wav:/home/dev/.claude/bell.wav:ro" \
    -v "${DOTFILES}/claude/statusline-command.sh:/home/dev/.claude/statusline-command.sh:ro" \
    -v "${HOME}/.claude/.credentials.json:/home/dev/.claude/.credentials.json:ro" \
    -v "${DOTFILES}/config/nvim:/home/dev/.config/nvim:ro" \
    --entrypoint bash \
    "$IMAGE_NAME"
